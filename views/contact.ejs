<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/head') %>
    <%- include('partials/styles') %>
    <style>
      form{
        --margin:.25em;
      }
      form .input-container{
        background-color: #DDDDDD;
      }
      form .icon i,form .input, form .textarea{
        color: var(--theme-brown);
      }
      form .input, form .textarea{
        background-color: transparent;
       
      }

    </style>

</head>

<body>
  <%- include('partials/header') %>
    <div class="is-flex row">
      <%- include('partials/sidebar') %>
        <main role="main" class="has-aside-sibling">
          <section class="section flow">
            <h2 class="title title-line is-relative">
              <span>Contact <span class="brown-txt">Us</span></span>
            </h2>
            <p>
              Lorem ipsum dolor sit amet consectetur adipisicing elit. Ducimus odit minima hic, sapiente deserunt
              repellat, facere dolorem voluptas omnis dicta molestiae. Voluptate sit praesentium veniam ab voluptates
              possimus vero odio!
            </p>
            <div class="mapouter">
              <div class="gmap_canvas">
                <iframe id="gmap_canvas"
                  src="https://maps.google.com/maps?q=federal%20university%20of%20health%20science%20otukpo&t=&z=13&ie=UTF8&iwloc=&output=embed"
                  frameborder="0" scrolling="no" marginheight="0" marginwidth="0"></iframe>
              </div>
            </div>
            <div class="columns">
              <div class="column">
              <form action="" class="is-flex is-column flow">
                  
                  <div class="input-container thin is-flex row is-centerdY">
                    <span class="icon"><i class="fas fa-user"></i></span>
                    <input class="input" type="text" placeholder="Enter your full name">
                   
                   </div>
                   <p class="help is-danger"></p>
                   <div class="input-container is-flex row is-centerdY">
                    <span class="icon"><i class="fas fa-envelope"></i></span>
                    <input class="input" type="email" placeholder="Email address">
                   </div>
                   <p class="help is-danger"></p>
                   <div class="input-container is-flex row">
                 
                    <textarea class="textarea" placeholder="write your message.."></textarea>
                   </div>
                   <p class="help is-success"></p>
                  
                   <button class="button has-bg-brown is-medium has-text-white">
                    Send message&nbsp; <i class="fa-solid fa-paper-plane"></i>
                  </button>
                     <p>
                      <strong>N:B</strong> Only a well structured and grammatically accurate message will be treated as relevant!
                     </p>
                  
                     
                   
              </form>
              </div>

              <div class="column flow  is-5-desktop">
                <div class="is-flex row p-4 is-centerdY box-sh">
                  <div class="is-box has-text-white  has-bg-brown p-3">
                    <div class="icon is-large"><i class="fa fa-map-marker-alt"></i></div>
                  </div>
                  <div class="ml-4">
                    <span class="is-size-4 is-uppercase theme-color">location</span><br>
                    <span class="">Maitama, Abuja, Nigeria</span>
                  </div>
                </div>
                <div class="is-flex row p-4 is-centerdY box-sh">
                  <div class="is-box has-text-white has-bg-brown p-3">
                    <div class="icon is-large"><i class="fa fa-envelope"></i></div>
                  </div>
                  <div class="ml-4">
                    <span class="is-size-4 is-uppercase theme-color">location</span><br>
                    <span class="">Maitama, Abuja, Nigeria</span>
                  </div>
                </div>
                <div class="is-flex row p-4 is-centerdY box-sh ">
                  <div class="is-box has-text-white has-bg-brown p-3">
                    <div class="icon is-large"><i class="fa fa-phone"></i></div>
                  </div>
                  <div class="ml-4">
                    <span class="is-size-4 is-uppercase theme-color">location</span><br>
                    <span class="">Maitama, Abuja, Nigeria</span>
                  </div>
                </div>
              </div>
            </div>
          </section>
           
        </main>
    </div>

    <%- include('partials/footer') %>
      <%- include('partials/top') %>
        <%- include('partials/scripts') %>

</body>

</html>