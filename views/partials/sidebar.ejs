<aside side-bar class="is-flex is-column px-3 quick-links right-border is-hidden-mobile">
    <h5 class="title is-5 brown-txt mt-4">FEATURED NEWS</h5>
   
    <% news.forEach((news)=> { %>
   
      <a href="" class="is-uppercase my-2 is-size-6">
        <span class="icon is-small mr-1 "><i class="fa-solid fa-flag"></i>
        </span> 
        <small>
         <%= news.body%>
        </small>
      </a>
     
    <% })%>
    
</aside>