<script>
    $(() => {
      var owl = $('.owl1'),
        owl2 = $('.owl2'),
        carouseList = [owl, owl2];
    
      carouseList.forEach((x) => {
        x.owlCarousel({
          nav: false,
          loop: true,
          autoplay: true,
          autoplayTimeout: 3000,
          autoplayHoverPause: true,
        })
      })
    
      owl.owlCarousel({
        margin: 10,
        responsiveClass: true,
        responsive: {
          0: {
            items: 1,
            autoHeight: true
          },
          600: {
            items: 3,
          },
          1000: {
            items: 4,
          }
        }
      });
    
      owl2.owlCarousel({
        items: 1,
        autoHeight: true,
      });
    })
    
    // $('.play').on('click',function(){
    //     owl.trigger('play.owl.autoplay',[1000])
    // })
    // $('.stop').on('click',function(){
    //     owl.trigger('stop.owl.autoplay')
    // })
    </script>
    