    <!-- The Modal/Lightbox -->
    <div class="modal" id="modal">
      <div class="modal-background"></div>
      <div class="modal-content scale-in-hor-center">
        <div class="mySlides">
          <div class="numbertext">1 / 4</div>
          <img height="800" width="650" src="/images/student-studying.png" style="width:100%;height:80%;">


        </div>

        <div class="mySlides">
          <div class="numbertext">2 / 4</div>
          <img height="800" width="650" src="/images/student-studying.png" style="width:100%">

        </div>

        <div class="mySlides">
          <div class="numbertext">3 / 4</div>
          <img height="800" width="650" src="/images/student-studying.png" style="width:100%">

        </div>

        <div class="mySlides">
          <div class="numbertext">4 / 4</div>
          <img height="800" width="650" src="/images/student-studying.png" style="width:100%">
        </div>

        <!-- Next/previous controls -->
        <a class="prev" onclick="plusSlides(-1)">&#10094;</a>
        <a class="next" onclick="plusSlides(1)">&#10095;</a>

        <!-- Caption text -->
        <div class="caption-container">
          <p id="caption"></p>
        </div>

        <!-- Thumbnail image controls -->
        <div class="columns is-mobile is-gapless">
          <div class="column">
            <img class="demo" height="400" width="400" src="/images/student-studying.png"
              onclick="openModal();currentSlide(1)" alt="students">
          </div>

          <div class="column">
            <img class="demo" height="400" width="400" src="/images/student-studying.png"
              onclick="openModal();currentSlide(2)" alt="graduands">
          </div>

          <div class="column">
            <img class="demo" height="400" width="400" src="/images/student-studying.png"
              onclick="openModal();currentSlide(3)" alt="graduands">
          </div>

          <div class="column">
            <img class="demo" height="400" width="400" src="/images/student-studying.png"
              onclick="openModal();currentSlide(4)" alt="graduands">
          </div>
        </div>
      </div>
      <button onclick="closeModal('modal')" class="modal-close is-large" aria-label="close"></button>
    </div>
    <div class="modal" id="modal2">
      <div class="modal-background"></div>
      <div class="modal-card br-15 scale-in-hor-center">
        <header class="modal-card-head transparent p-1 is-flex is-justify-content-flex-end">

          <button onclick="closeModal('modal2')" class="delete" aria-label="close"></button>
        </header>
        <section class="modal-card-body transparent">
          <small class="menu-label is-uppercase letter-space theme-color has-text-weight-semibold">dont
            miss out any information</small>
          <p class="modal-card-title brown-txt is-uppercase is-size-6-mobile has-text-weight-semibold mt-4">
            subscribe to our news letter 
          </p>
          <p class="mt-1">
            Get important updates on
          <ul class="theme-list">
            <li>campus activities/events</li>
            <li>Admissions</li>
            <li>staff recruitment</li>
            <li>and more....</li>
          </ul>
          </p>
          <form class="mt-4" action="">

            <div class="field">
              <div class="control has-icons-left has-icons-right">
                <input class="input is-rounded has-border thin" type="email" placeholder="enter your email" required>
                <span class="icon is-small is-left">
                  <i class="fas fa-envelope"></i>
                </span>

              </div>
            </div>
            <button class="button is-rounded theme-brown has-text-white" type="submit" style="width:100%;" 
            class="theme-brown py-4 has-text-white"> Subscribe &nbsp; <i class="fa-solid fa-paper-plane"></i></button>


          </form>

        </section>
        <footer class="modal-card-foot theme-gradient">
          <!-- <button class="has-background-white">Subscribe  <i class="fa-solid fa-paper-plane"></i></button>
      <button onclick="closeModal('modal2')" class="button is-white">Cancel</button> -->
        </footer>
      </div>
    </div>

