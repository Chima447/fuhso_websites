    <main role="main">
      <!-- LATEST NOW -->
      <section class="section pt-5">
        <div class="container ">
          <div class="columns pt-6">
            <div class="column ">
              <h2 class="title title-line is-relative">
                <span> Latest <span class="brown-txt">Now</span></span>
              </h2>
              <% latest.forEach((x)=>{ %>
                <div class="featured-news is-flex row has-gap m-1 pb-3">
                  <div class="news-image">
                    <img loading="lazy" src="/images/<%=x.image%>" alt="<%=x.image%>">
                  </div>
                  <div class="news-content is-flex is-column">
                    <a class="brown-txt is-uppercase is-underlined" href="#">
                      <%=x.title%>
                    </a>
                    <div class="menu-label"> <i class="fa-solid fa-flag"></i>
                      <%= x.date%>
                    </div>
                    <%= x.body.length > 100 ? x.body.slice(0, 150) + '  ...' : x.body %>
                  </div>
                </div>
                <% }) %>

            </div>
            <div class="column is-4-desktop">
              <h3 class="title is-size-4-mobile title-arrow is-relative has-border theme-bg  p-2">
                <span class="ml-3 has-text-white "> Featured News</span>
              </h3>
              <div class="theme-gradient is-flex is-column p-3 has-text-white quick-links">
                <% news.forEach((news)=> { %>
                  <a class="has-text-white" href="">
                    <span class="icon is-small mr-1"><i class="fa-solid fa-flag"></i>
                    </span>
                    <%= news.body%>

                  </a>
                  <% })%>

              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <h2 class="title title-line is-relative">
            <span> About <span class="brown-txt"> FUHSO</span></span>

          </h2>
          <div class="columns mt-6 is-vcentered">
            <div class="column has-text-justified flow">
              <div class="is-flex is-row is-centerdX ">
                <img width="200" height="200" src="images/logo.png" alt=" fuhso logo">
              </div>
              <p>
                Welcome to FUHSO. The Federal University of Health Sciences, Otukpo is a world-class specialized
                University that will train and produce high-quality healthcare professionals that will contribute to the
                development of the health sector in Nigeria, and the University will be equipped with state-of-the-art
                equipment for research and teaching. It will be the first of..

                <a class="brown-txt is-underlined pt-1"> read more &#8594;</a>
              </p>
            </div>
            <div class="column has-text-justified">
              <div class="flow">
                <h4 class="has-text-white has-bg-brown styled-header">Our Vision</h4>
                <p class="has-background-white box-sh styled-body">
                  <q>To be a world class institution for learning, scientific research and innovation for developing the
                    next generation of IT professionals</q>
                </p>
              </div>
              <div class="flow mt-4">
                <h4 class="has-text-white has-bg-brown styled-header">Our Mission</h4>
                <p class="has-background-white box-sh styled-body">
                  <q>To build capacity of Health care professionals through integrated medical education, professional
                    skills and research providing access to high quality healthcare services
                </p>

              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- PHILOSOPHY -->
      <section class="section theme-bg is-light">
        <div class="container  left-border">
          <div class="columns is-centered is-flex is-column">
            <h2 class="title is-relative has-text-white">
              &nbsp; philosopy
